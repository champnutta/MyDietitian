rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function isLinkedOwner(userId) {
      return signedIn()
        && exists(/databases/$(database)/documents/authLinks/$(request.auth.uid))
        && get(/databases/$(database)/documents/authLinks/$(request.auth.uid)).data.canonicalUserId == userId;
    }

    function canAccessUser(userId) {
      return isOwner(userId) || isLinkedOwner(userId) || isAdmin();
    }

    function canAccessRecord(data) {
      return canAccessUser(data.userId) || canAccessUser(data.canonicalUserId);
    }

    function isAdmin() {
      return signedIn() && request.auth.token.admin == true;
    }

    match /users/{userId} {
      allow read, write: if canAccessUser(userId);
    }

    match /profiles/{userId} {
      allow read, write: if canAccessUser(userId);
    }

    match /subscriptions/{userId} {
      allow read: if canAccessUser(userId);
      allow write: if isAdmin();
    }

    match /subscriptionPlans/{planId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /mealLogs/{mealLogId} {
      allow create: if signedIn() &&
        canAccessRecord(request.resource.data);
      allow read, update, delete: if (
        canAccessRecord(resource.data)
      );
    }

    match /exerciseLogs/{exerciseLogId} {
      allow create: if signedIn() &&
        canAccessRecord(request.resource.data);
      allow read, update, delete: if (
        canAccessRecord(resource.data)
      );
    }

    match /weightLogs/{weightLogId} {
      allow create: if signedIn() &&
        canAccessRecord(request.resource.data);
      allow read, update, delete: if (
        canAccessRecord(resource.data)
      );
    }

    match /feedback/{feedbackId} {
      allow create: if signedIn() &&
        canAccessRecord(request.resource.data);
      allow read: if canAccessRecord(resource.data);
      allow update, delete: if isAdmin();
    }

    match /aiRuns/{runId} {
      allow read: if canAccessRecord(resource.data);
      allow write: if isAdmin();
    }

    match /coachConsultations/{consultationId} {
      allow read: if canAccessRecord(resource.data);
      allow write: if isAdmin();
    }

    match /biaReports/{biaReportId} {
      allow read: if canAccessRecord(resource.data);
      allow write: if isAdmin();
    }

    match /profileEvents/{eventId} {
      allow read: if canAccessRecord(resource.data);
      allow write: if isAdmin();
    }

    match /profileAuthEvents/{eventId} {
      allow read: if canAccessRecord(resource.data);
      allow write: if isAdmin();
    }

    match /subscriptionRequests/{requestId} {
      allow read: if canAccessRecord(resource.data);
      allow write: if isAdmin();
    }

    match /paymentReviews/{reviewId} {
      allow read: if canAccessRecord(resource.data);
      allow write: if isAdmin();
    }

    match /subscriptionEvents/{eventId} {
      allow read: if canAccessRecord(resource.data);
      allow write: if isAdmin();
    }

    match /redeemCodes/{code} {
      allow read, write: if isAdmin();
    }

    match /migrationRuns/{importRunId} {
      allow read, write: if isAdmin();
    }

    match /lineEvents/{eventId} {
      allow read, write: if isAdmin();
    }

    match /lineEventDedup/{messageId} {
      allow read, write: if isAdmin();
    }

    match /lineUnsupportedFiles/{fileId} {
      allow read, write: if isAdmin();
    }

    match /adminContactRequests/{requestId} {
      allow read, write: if isAdmin();
    }

    match /adminChatMessages/{messageId} {
      allow read, write: if isAdmin();
    }

    match /adminChatSessions/{sessionId} {
      allow read, write: if isAdmin();
    }

    match /lineLinks/{lineUserId} {
      allow read, write: if isAdmin();
    }

    match /authLinks/{firebaseAuthUid} {
      allow read, write: if isAdmin();
    }

    match /aiAgents/{agentId} {
      allow read, write: if isAdmin();
    }

    match /appConfig/{configId} {
      allow read, write: if isAdmin();
    }

    match /adminAuditLogs/{logId} {
      allow read, write: if isAdmin();
    }
  }
}
